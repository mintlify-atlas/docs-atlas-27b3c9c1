  "keyFeatures": [
    "EKS Auto Mode with built-in and custom node pools",
    "EKS Managed Node Groups with custom launch templates",
    "Self-Managed Node Groups with full EC2 Auto Scaling customization",
    "Fargate Profiles for serverless compute",
    "Karpenter sub-module for intelligent node autoscaling",
    "EKS Hybrid Nodes for connecting on-premises and edge nodes",
    "IRSA (IAM Roles for Service Accounts) via OIDC provider",
    "Cluster Access Entries for IAM-based authentication",
    "KMS encryption for secrets at rest",
    "EFA (Elastic Fabric Adapter) support for high-performance networking",
    "EKS Provisioned Control Plane scaling tiers",
    "CloudWatch logging for control plane audit and API logs"
  ],
